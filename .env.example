# OpenClaw Environment Variables
# Copy to .env and populate with actual values
# NEVER commit .env to git

# Telegram C2
TELEGRAM_BOT_TOKEN=
OPERATOR_CHAT_ID=

# GitHub
GITHUB_PAT=

# Infrastructure
TAILSCALE_IP=
AWS_REGION=ap-southeast-2

# Paths (defaults - modify if workspace moved)
OPENCLAW_WORKSPACE=/root/.openclaw/workspace
NEOPAY_SKILLS_PATH=/root/.openclaw/workspace/neopay
KNOWLEDGE_BASE=/root/.openclaw/workspace/knowledge
