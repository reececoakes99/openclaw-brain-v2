{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"}
  ],
  "title": "Payment Switch - Overview",
  "uid": "payment-switch-overview",
  "version": 1,
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Transactions Per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "rate(payment_transactions_total[1m])", "legendFormat": "TPS"}],
      "fieldConfig": {"defaults": {"unit": "ops", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 500}, {"color": "green", "value": 1500}]}}}
    },
    {
      "id": 2,
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(payment_request_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(payment_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(payment_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "targets": [{"expr": "rate(payment_errors_total[5m]) / rate(payment_transactions_total[5m]) * 100", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 4,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "targets": [{"expr": "payment_active_connections", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}}
    },
    {
      "id": 5,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [{"expr": "payment_queue_depth", "legendFormat": "Queue"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}]}}}
    },
    {
      "id": 6,
      "title": "MTI Message Distribution",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [{"expr": "sum by (mti) (rate(payment_messages_total[5m]))", "legendFormat": "{{mti}}"}]
    },
    {
      "id": 7,
      "title": "HSM Operations/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "rate(hsm_key_generation_total[5m])", "legendFormat": "Key Gen"},
        {"expr": "rate(hsm_mac_verification_total[5m])", "legendFormat": "MAC Verify"},
        {"expr": "rate(hsm_pin_operations_total[5m])", "legendFormat": "PIN Ops"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 8,
      "title": "Response Codes",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "sum by (response_code) (rate(payment_responses_total[5m]))", "legendFormat": "{{response_code}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["payment-switch", "overview", "production"],
  "annotations": {"list": []}
}