{
  "title": "Playwrights Overview",
  "uid": "playwrights-overview",
  "version": 1,
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(playwrights_http_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "id": 2,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(playwrights_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(playwrights_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(playwrights_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 2}}
      }
    },
    {
      "id": 3,
      "title": "Browser Health",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "targets": [
        {"expr": "sum(rate(playwrights_browser_launches_total{status=\"crashed\"}[5m])) / sum(rate(playwrights_browser_launches_total[5m])) * 100"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1}]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "targets": [
        {"expr": "sum(playwrights_queue_depth) by (worker_id)", "legendFormat": "{{worker_id}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"fillOpacity": 20}
        }
      }
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [
        {"expr": "(sum(rate(playwrights_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(playwrights_http_requests_total[5m]))) * 100"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "DB Query Duration",
      "type": "histogram",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {"expr": "rate(playwrights_db_query_duration_seconds_bucket[5m])"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 7,
      "title": "Redis Ops/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "sum(rate(playwrights_queue_adds_total[1m]))", "legendFormat": "enqueue"},
        {"expr": "sum(rate(playwrights_queue_processed_total[1m]))", "legendFormat": "dequeue"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 8,
      "title": "Browser Launch Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {"expr": "sum(rate(playwrights_browser_launches_total{status=\"success\"}[1m]))", "legendFormat": "success"},
        {"expr": "sum(rate(playwrights_browser_launches_total{status=\"crashed\"}[1m]))", "legendFormat": "crashed"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"fillOpacity": 10}
        }
      }
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "datasource": {"type": "prometheus", "uid": "playwrights-prometheus"}
}